<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InfraDroneDesktop.Views.LicenseView"
             Background="#0f1923">
  <ScrollViewer>
    <StackPanel Margin="24" Spacing="16" MaxWidth="700">

      <!-- Header -->
      <StackPanel Spacing="4">
        <TextBlock Text="License &amp; Encryption" FontSize="18" FontWeight="Bold"
                   Foreground="#e2e8f0"/>
        <TextBlock Text="InfraDrone GCS — DAMbv BV proprietary software"
                   FontSize="11" Foreground="#64748b"/>
      </StackPanel>

      <!-- License status -->
      <Border Background="#1a2637" CornerRadius="8" Padding="16"
              BorderBrush="#1e3a5f" BorderThickness="0.5">
        <StackPanel Spacing="8">
          <TextBlock Text="LICENSE STATUS" FontSize="9" FontWeight="Bold"
                     Foreground="#4a5568" LetterSpacing="1"/>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Ellipse Name="LicenseDot" Width="10" Height="10" Fill="#ef4444"/>
            <TextBlock Name="LicenseStatus" Text="No license installed"
                       FontSize="13" Foreground="#e2e8f0" VerticalAlignment="Center"/>
          </StackPanel>
          <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Licensed to" FontSize="10" Foreground="#64748b" Margin="0,2"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Name="LicensedTo" Text="—" FontSize="10" Foreground="#e2e8f0" Margin="0,2"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Operator" FontSize="10" Foreground="#64748b" Margin="0,2"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Name="LicenseOperator" Text="—" FontSize="10" Foreground="#e2e8f0" Margin="0,2"/>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Device ID" FontSize="10" Foreground="#64748b" Margin="0,2"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Name="DeviceId" Text="—" FontSize="10" Foreground="#e2e8f0" FontFamily="Consolas" Margin="0,2"/>
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Expires" FontSize="10" Foreground="#64748b" Margin="0,2"/>
            <TextBlock Grid.Row="3" Grid.Column="1" Name="LicenseExpiry" Text="—" FontSize="10" Foreground="#e2e8f0" Margin="0,2"/>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Encryption status -->
      <Border Background="#1a2637" CornerRadius="8" Padding="16"
              BorderBrush="#1e3a5f" BorderThickness="0.5">
        <StackPanel Spacing="8">
          <TextBlock Text="ENCRYPTION" FontSize="9" FontWeight="Bold"
                     Foreground="#4a5568" LetterSpacing="1"/>
          <TextBlock Text="AES-256-GCM end-to-end encryption for MAVLink telemetry and commands."
                     FontSize="11" Foreground="#94a3b8" TextWrapping="Wrap"/>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Ellipse Name="EncryptDot" Width="10" Height="10" Fill="#ef4444"/>
            <TextBlock Name="EncryptStatus" Text="Encryption disabled — no valid license"
                       FontSize="11" Foreground="#94a3b8" VerticalAlignment="Center"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Issue license (DAMbv admin only) -->
      <Border Background="#1a2637" CornerRadius="8" Padding="16"
              BorderBrush="#1e3a5f" BorderThickness="0.5">
        <StackPanel Spacing="10">
          <TextBlock Text="ISSUE NEW LICENSE" FontSize="9" FontWeight="Bold"
                     Foreground="#4a5568" LetterSpacing="1"/>
          <TextBlock Text="Issue a license for this device. Only DAMbv administrators can issue licenses."
                     FontSize="11" Foreground="#64748b" TextWrapping="Wrap"/>
          <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto" Margin="0,4">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Operator name" FontSize="11" Foreground="#94a3b8" VerticalAlignment="Center" Margin="0,4"/>
            <TextBox Grid.Row="0" Grid.Column="1" Name="OperatorInput"
                     Watermark="e.g. DAMbv BV" Background="#0f1923"
                     Foreground="#e2e8f0" BorderBrush="#2d3f52" BorderThickness="0.5"
                     Padding="8,4" CornerRadius="4" Margin="8,4"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Issued to" FontSize="11" Foreground="#94a3b8" VerticalAlignment="Center" Margin="0,4"/>
            <TextBox Grid.Row="1" Grid.Column="1" Name="IssuedToInput"
                     Watermark="e.g. Sam Tahir" Background="#0f1923"
                     Foreground="#e2e8f0" BorderBrush="#2d3f52" BorderThickness="0.5"
                     Padding="8,4" CornerRadius="4" Margin="8,4"/>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Valid days" FontSize="11" Foreground="#94a3b8" VerticalAlignment="Center" Margin="0,4"/>
            <NumericUpDown Grid.Row="2" Grid.Column="1" Name="ValidDaysInput"
                           Value="365" Minimum="30" Maximum="1825"
                           Margin="8,4" Background="#0f1923" Foreground="#e2e8f0"/>
          </Grid>
          <TextBox Name="TargetDeviceId" Watermark="Target device ID (leave blank for this device)"
                   Background="#0f1923" Foreground="#e2e8f0"
                   BorderBrush="#2d3f52" BorderThickness="0.5"
                   Padding="8,4" CornerRadius="4" Margin="0,0,0,8"
                   FontFamily="Consolas"/>
          <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Name="BtnIssue" Content="🔑 Issue license for this device" Click="OnIssue"
                  Background="#0d3d2e" Foreground="#0d9e75"
                  BorderBrush="#0d9e75" BorderThickness="0.5"
                  Padding="12,6" CornerRadius="6" HorizontalAlignment="Left"/>
          </StackPanel>
          <Button Name="BtnImport" Content="📂 Import license file" Click="OnImport"
                  Background="#1a2637" Foreground="#94a3b8"
                  BorderBrush="#2d3f52" BorderThickness="0.5"
                  Padding="12,6" CornerRadius="6" HorizontalAlignment="Left"/>
          <TextBlock Name="IssueStatus" Text="" FontSize="11" Foreground="#0d9e75"/>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
