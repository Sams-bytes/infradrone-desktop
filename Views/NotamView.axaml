<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InfraDroneDesktop.Views.NotamView"
             Background="#0f1923">
  <Grid RowDefinitions="Auto,Auto,*">

    <!-- Header -->
    <Border Grid.Row="0" Background="#1a2637" Padding="16,12">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <StackPanel>
          <TextBlock Text="NOTAM Checker" FontSize="16" FontWeight="Bold" Foreground="#e2e8f0"/>
          <TextBlock Name="StatusText" Text="Not loaded" FontSize="11" Foreground="#64748b"/>
        </StackPanel>
        <Button Grid.Column="1" Name="BtnRefresh" Content="⟳ Refresh"
                Background="#0d3d2e" Foreground="#0d9e75"
                BorderBrush="#0d9e75" BorderThickness="0.5"
                Padding="12,6" CornerRadius="6" Margin="8,0"
                Click="OnRefresh"/>
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
          <Border Background="#3d1515" BorderBrush="#ef4444" BorderThickness="0.5"
                  CornerRadius="4" Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Name="ActiveCount" Text="0" FontSize="13" FontWeight="Bold" Foreground="#ef4444"/>
              <TextBlock Text="ACTIVE" FontSize="10" Foreground="#ef4444" VerticalAlignment="Center"/>
            </StackPanel>
          </Border>
          <Border Background="#1a2637" BorderBrush="#2d3f52" BorderThickness="0.5"
                  CornerRadius="4" Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Name="TotalCount" Text="0" FontSize="13" FontWeight="Bold" Foreground="#94a3b8"/>
              <TextBlock Text="TOTAL" FontSize="10" Foreground="#64748b" VerticalAlignment="Center"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Filter bar -->
    <Border Grid.Row="1" Background="#131f2e" Padding="16,8"
            BorderBrush="#1e3a5f" BorderThickness="0,1">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Text="Filter:" FontSize="11" Foreground="#64748b" VerticalAlignment="Center"/>
        <Button Name="BtnAll" Content="All" Classes="filter-btn filter-active" Click="OnFilterAll"/>
        <Button Name="BtnEHGG" Content="EHGG Groningen" Classes="filter-btn" Click="OnFilterEHGG"/>
        <Button Name="BtnEHAA" Content="EHAA FIR" Classes="filter-btn" Click="OnFilterEHAA"/>
        <Button Name="BtnActive" Content="Active only" Classes="filter-btn" Click="OnFilterActive"/>
      </StackPanel>
    </Border>

    <!-- NOTAM list -->
    <ScrollViewer Grid.Row="2">
      <StackPanel Name="NotamList" Spacing="1" Margin="0"/>
    </ScrollViewer>

  </Grid>
</UserControl>
